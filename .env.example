# Optional Docker image overrides for environments where Docker Hub is slow
# or blocked. Copy this file to `.env` and replace values with an accessible
# mirror or private registry when needed.
#
# Examples:
# FOODCONTROL_BACKEND_BASE_IMAGE=mirror.gcr.io/library/python:3.12-slim
# FOODCONTROL_FRONTEND_BASE_IMAGE=mirror.gcr.io/library/node:20-alpine
# FOODCONTROL_POSTGRES_BASE_IMAGE=mirror.gcr.io/library/postgres:15-alpine

FOODCONTROL_BACKEND_BASE_IMAGE=mirror.gcr.io/library/python:3.12-slim
FOODCONTROL_FRONTEND_BASE_IMAGE=mirror.gcr.io/library/node:20-alpine
FOODCONTROL_POSTGRES_BASE_IMAGE=mirror.gcr.io/library/postgres:15-alpine
